{ self, inputs, ... }: {
  flake.nixosModules.inputMethod = { config, pkgs, ... }:
    let
      # 通过覆写，将你需要的所有 rime 方案打包到一起
      myFcitx5Rime = pkgs.fcitx5-rime.override {
        rimeDataPkgs = with pkgs; [
          rime-data # 基础方案
          rime-wanxiang # 一个流行的方案集合
        ];
      };
    in
    {
      i18n.inputMethod = {
        enable = true;
        type = "fcitx5";
        fcitx5.addons = with pkgs; [
          myFcitx5Rime
          qt6Packages.fcitx5-configtool
          catppuccin-fcitx5
          fcitx5-tokyonight

        ];
      };

      environment.sessionVariables = {
        GTK_IM_MODULE = "fcitx";
        QT_IM_MODULE = "fcitx";
        XMODIFIERS = "@im=fcitx";
        SDL_IM_MODULE = "fcitx";
      };
    };
}
